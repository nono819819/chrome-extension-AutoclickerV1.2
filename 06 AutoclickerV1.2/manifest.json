{
  "manifest_version": 3,
  "name": "Ripple AutoClicker (CPS)",
  "version": "1.3",
  "description": "High-speed clicking with ripples and shortcuts.",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Toggle AutoClicker"
    }
  }
}